# Multi-Aspect E-Commerce Semantic Engine — Environment Configuration
# Copy to .env and adjust values for your environment.

# ── Qdrant ─────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=commerce_products

# ── Embedding Backend ──────────────────────────────────────────────
# "production"     — Uses real ML models (ColBERT, BGE, ViT, SigLIP)
# "deterministic"  — Hash-based fake vectors for testing without models
EMBEDDING_BACKEND=deterministic

# ── Model Names (production mode only) ─────────────────────────────
TEXT_LATE_MODEL=answerdotai/answerai-colbert-small-v1
REVIEW_MODEL=BAAI/bge-small-en-v1.5
VISION_ALIGNMENT_MODEL=google/siglip-base-patch16-224

# ── Device ─────────────────────────────────────────────────────────
# "cpu" or "cuda" or "mps" (Apple Silicon)
DEVICE=cpu

# ── Search Tuning ──────────────────────────────────────────────────
PREFETCH_LIMIT=50
FINAL_LIMIT=10

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
